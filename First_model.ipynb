# Tabular Q-learning
def train_tabular_q_learning(
    env,
    n_episodes=1000000,
    alpha=0.10,         # learning rate
    gamma=1.00,        
    epsilon_start=1.0,  # exploration probability
    epsilon_min=0.05,
    epsilon_decay=0.99995,
    seed=42
):

    rng = np.random.default_rng(seed)

    # Initialize the Q-table
    Q = defaultdict(lambda: np.zeros(env.action_space.n, dtype=np.float32))

    epsilon = float(epsilon_start)
    
    # play hands
    for ep in range(n_episodes):
        s, _ = env.reset()
        done = False

        # loop training
        while not done:
            if rng.random() < epsilon:
                a = env.action_space.sample()
            else:
                a = int(np.argmax(Q[s]))
    
            # Apply the action to the environment
            s2, r, terminated, truncated, _ = env.step(a)
            done = terminated or truncated
        
            # Compute the Q-learning target
            best_next = 0.0 if done else float(np.max(Q[s2]))
            target = r + gamma * best_next
    
            # Update the Q-table (learning happens here)
            Q[s][a] += alpha * (target - float(Q[s][a]))
            s = s2

    # decrease epsilon after each episode
    epsilon = max(epsilon_min, epsilon * epsilon_decay)

    return Q

# finalize
def make_greedy_policy(Q):
    def policy(state):
        return int(np.argmax(Q[state]))
    return policy    
